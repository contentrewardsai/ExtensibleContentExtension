{
  "id": "asterSpotTrade",
  "label": "Aster spot (trade)",
  "category": "data",
  "description": "Signed spot TRADE on sapi.asterdex.com: placeOrder, cancel, cancel all on symbol, batchOrders. Optional dryRun, validateExchangeFilters, roundToExchangeFilters. Requires Allow spot trading + same keys as futures.",
  "defaultAction": {
    "type": "asterSpotTrade",
    "runIf": "",
