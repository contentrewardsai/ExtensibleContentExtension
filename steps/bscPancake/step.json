{
  "id": "bscPancake",
  "label": "BSC PancakeSwap / pool",
  "category": "data",
  "description": "Automated BSC on-chain actions via hot wallet: native BNB transfer, ERC20 transfer, WBNB wrap/unwrap (pinned WBNB), PancakeSwap V2 router swaps (fee-on-transfer variants, exact-output, tokens↔BNB via WBNB path), V3 concentrated-liquidity swaps (pinned SwapRouter) and V3 position mint / increase / partial decrease / collect / burn (pinned NonfungiblePositionManager; tick ranges), PancakeSwap Infinity Liquidity Book add/remove and exact-in / exact-out single-pool swaps via pinned BinPositionManager (@pancakeswap/infinity-sdk), raw modifyLiquidities payload, Permit2 approve for Bin PM, Infinity farm CAKE claim (Merkle API + Distributor), V2 liquidity, MasterChef farms, legacy CAKE staking. Settings → BSC / PancakeSwap. Unlock encrypted wallets once per session before signing. Never put private keys in workflow JSON.",
  "defaultAction": {
    "type": "bscPancake",
    "runIf": "",
    "operation": "swapExactTokensForTokens",
    "to": "",
    "token": "",
    "spender": "",
    "amount": "",
    "path": "",
    "amountIn": "",
    "amountOutMin": "",
    "amountOut": "",
    "amountInMax": "",
    "ethWei": "",
    "tokenA": "",
    "tokenB": "",
    "tokenIn": "",
    "tokenOut": "",
    "v3Fee": "",
    "v3Path": "",
    "tickLower": "",
    "tickUpper": "",
    "v3PositionTokenId": "",
    "v3Amount0Desired": "",
    "v3Amount1Desired": "",
    "v3Amount0Min": "",
    "v3Amount1Min": "",
    "v3Liquidity": "",
    "v3Amount0Max": "",
    "v3Amount1Max": "",
    "sqrtPriceLimitX96": "",
    "swapRouterV3Address": "",
    "positionManagerAddress": "",
    "amountADesired": "",
    "amountBDesired": "",
    "amountAMin": "",
    "amountBMin": "",
    "liquidity": "",
    "pid": "",
    "routerAddress": "",
    "masterChefAddress": "",
    "deadline": "",
    "waitConfirmations": 1,
    "gasLimit": "",
    "saveTxHashVariable": "bscTxHash",
    "saveExplorerUrlVariable": "bscExplorerUrl",
    "saveV3PositionTokenIdVariable": "",
    "infinityFee": "",
    "binStep": "",
    "infinityHooks": "",
    "infinityHooksRegistrationJson": "",
    "binPoolManagerAddress": "",
    "binPositionManagerAddress": "",
    "infiPoolInitialized": false,
    "infiLiquidityShape": "Spot",
    "infiActiveIdDesired": "",
    "infiIdSlippage": "",
    "infiLowerBinId": "",
    "infiUpperBinId": "",
    "infiAmount0": "",
    "infiAmount1": "",
    "infiAmount0Max": "",
    "infiAmount1Max": "",
    "infiDeadline": "",
    "infiModifyHookData": "",
    "infiPayload": "",
    "infiAmount0Min": "",
    "infiAmount1Min": "",
    "infiRemoveBinIds": "",
    "infiRemoveShares": "",
    "infiFarmClaimTs": "",
    "infiFarmClaimSkipIfNoRewards": false,
    "distributorAddress": "",
    "permit2Spender": "",
    "permit2Amount": "",
    "permit2Expiration": "",
    "infiSwapAmountIn": "",
    "infiSwapAmountOutMin": "",
    "infiSwapAmountOut": "",
    "infiSwapAmountInMax": "",
    "infiSwapCurrencyIn": "",
    "infiBinPathJson": "",
    "infiSwapZeroForOne": false,
    "saveInfiPositionTokenIdVariable": "",
    "saveInfiFarmClaimOutcomeVariable": ""
  },
  "formSchema": [
    { "key": "runIf", "label": "Run only if (optional)", "inputType": "text", "placeholder": "{{var}} or variable name" },
    { "key": "operation", "label": "Operation", "inputType": "select", "options": [
      { "value": "transferNative", "label": "transferNative (send BNB; to + ethWei or max/balance after gas reserve)" },
      { "value": "transferErc20", "label": "transferErc20 (ERC20 transfer; token + to + amount or max/balance)" },
      { "value": "wrapBnb", "label": "wrapBnb (BNB → WBNB; ethWei or max/balance after reserve)" },
      { "value": "unwrapWbnb", "label": "unwrapWbnb (WBNB → BNB; amount or max/balance)" },
      { "value": "approve", "label": "approve (ERC20 → router or MasterChef)" },
      { "value": "swapExactTokensForTokens", "label": "swapExactTokensForTokens (ERC20 → ERC20)" },
      { "value": "swapTokensForExactTokens", "label": "swapTokensForExactTokens (exact token out; amountInMax)" },
      { "value": "swapExactTokensForETH", "label": "swapExactTokensForETH (ERC20 → BNB; path ends WBNB)" },
      { "value": "swapTokensForExactETH", "label": "swapTokensForExactETH (exact BNB wei out; amountInMax; path ends WBNB)" },
      { "value": "swapExactETHForTokens", "label": "swapExactETHForTokens (BNB → tokens; path starts WBNB)" },
      { "value": "swapETHForExactTokens", "label": "swapETHForExactTokens (BNB → exact token out)" },
      { "value": "swapExactTokensForTokensSupportingFeeOnTransferTokens", "label": "Fee-on-transfer: ERC20 → ERC20 (same fields as exact token swap)" },
      { "value": "swapExactETHForTokensSupportingFeeOnTransferTokens", "label": "Fee-on-transfer: BNB → tokens (path starts WBNB)" },
      { "value": "swapExactTokensForETHSupportingFeeOnTransferTokens", "label": "Fee-on-transfer: tokens → BNB (path ends WBNB)" },
      { "value": "addLiquidity", "label": "addLiquidity (two ERC20s)" },
      { "value": "addLiquidityETH", "label": "addLiquidityETH (token + BNB; use token + amount fields)" },
      { "value": "removeLiquidity", "label": "removeLiquidity (two ERC20s; liquidity or max/balance)" },
      { "value": "removeLiquidityETH", "label": "removeLiquidityETH (token–WBNB; liquidity or max/balance)" },
      { "value": "farmDeposit", "label": "farm deposit (pid + amount or max/balance = all LP in wallet)" },
      { "value": "farmWithdraw", "label": "farm withdraw (pid + amount or max/balance = full stake)" },
      { "value": "farmHarvest", "label": "farm harvest (deposit pid, 0)" },
      { "value": "farmEnterStaking", "label": "enterStaking (MC v1; amount or max/balance)" },
      { "value": "farmLeaveStaking", "label": "leaveStaking (MC v1; amount or max/balance)" },
      { "value": "v3SwapExactInputSingle", "label": "V3 swap exact in single pool (tokenIn, tokenOut, v3Fee, amountIn, amountOutMin)" },
      { "value": "v3SwapExactOutputSingle", "label": "V3 swap exact out single pool (tokenIn, tokenOut, v3Fee, amountOut, amountInMax)" },
      { "value": "v3SwapExactInput", "label": "V3 swap exact in multi-hop (v3Path token,fee,token,...; amountIn; amountOutMin)" },
      { "value": "v3SwapExactOutput", "label": "V3 swap exact out multi-hop (v3Path forward; amountOut; amountInMax)" },
      { "value": "v3PositionMint", "label": "V3 new position (tokenA/B, v3Fee, tickLower/Upper, amounts; NFT id → save var)" },
      { "value": "v3PositionIncreaseLiquidity", "label": "V3 add to existing position (v3PositionTokenId; v3Amount0/1 Desired+Min = pool token0/token1)" },
      { "value": "v3PositionDecreaseLiquidity", "label": "V3 remove partial liquidity (v3Liquidity uint128 or max; then collect)" },
      { "value": "v3PositionCollect", "label": "V3 collect owed tokens (fees/principal after decrease)" },
      { "value": "v3PositionBurn", "label": "V3 burn empty position NFT (liquidity must be 0)" },
      { "value": "permit2Approve", "label": "Permit2 approve (token + BinPositionManager spender + uint160 amount + uint48 expiration)" },
      { "value": "infiBinAddLiquidity", "label": "Infinity Bin add liquidity (SDK multicall → BinPositionManager; needs Permit2 + pool fields)" },
      { "value": "infiBinRemoveLiquidity", "label": "Infinity Bin remove liquidity (bin ids + share amounts parallel list)" },
      { "value": "infiBinModifyLiquidities", "label": "Infinity Bin modifyLiquidities (advanced: infiPayload bytes + infiDeadline)" },
      { "value": "infiBinSwapExactInSingle", "label": "Infinity Bin swap exact in single pool (BIN_SWAP_EXACT_IN_SINGLE + settle/take; Permit2 for ERC20 in)" },
      { "value": "infiBinSwapExactIn", "label": "Infinity Bin swap exact in multi-hop (infiBinPathJson + infiSwapCurrencyIn; Permit2 for ERC20 in)" },
      { "value": "infiBinSwapExactOut", "label": "Infinity Bin swap exact out multi-hop (path JSON + infiSwapAmountOut + infiSwapAmountInMax)" },
      { "value": "infiBinSwapExactOutSingle", "label": "Infinity Bin swap exact out single pool (BIN_SWAP_EXACT_OUT_SINGLE; infiSwapAmountOut + infiSwapAmountInMax)" },
      { "value": "infiFarmClaim", "label": "Infinity farm CAKE claim (fetches Merkle proof from Pancake API → Distributor)" }
    ] },
    { "key": "to", "label": "To address (transferNative / transferErc20)", "inputType": "text" },
    { "key": "token", "label": "Token (approve / transferErc20 / addLiquidityETH / removeLiquidityETH)", "inputType": "text", "placeholder": "ERC20 (not WBNB for ETH liquidity ops)" },
    { "key": "spender", "label": "Spender (approve, optional)", "inputType": "text", "hint": "Default: V2 router; or pinned V3 SwapRouter / NPM / MasterChef" },
    { "key": "amount", "label": "Amount (approve / transferErc20 / unwrapWbnb / farm / enter & leave staking)", "inputType": "text", "placeholder": "uint256; max/balance where supported (see docs)" },
    { "key": "path", "label": "Swap path (comma-separated)", "inputType": "text", "placeholder": "tokenIn, WBNB, tokenOut" },
    { "key": "amountIn", "label": "amountIn (swap; max/balance = path[0] balance)", "inputType": "text" },
    { "key": "amountOutMin", "label": "amountOutMin (swap / swapExactETH)", "inputType": "text" },
    { "key": "amountOut", "label": "amountOut (exact token out or exact BNB wei for swapTokensForExact*)", "inputType": "text" },
    { "key": "amountInMax", "label": "amountInMax (exact-out swaps; max = unlimited)", "inputType": "text" },
    { "key": "ethWei", "label": "ethWei (wei, or max/balance after gas reserve)", "inputType": "text", "placeholder": "Wei or max / balance" },
    { "key": "tokenIn", "label": "tokenIn (V3 single-hop swap)", "inputType": "text" },
    { "key": "tokenOut", "label": "tokenOut (V3 single-hop swap)", "inputType": "text" },
    { "key": "v3Fee", "label": "v3Fee (uint24 tier, e.g. 100, 500, 2500, 10000)", "inputType": "text" },
    { "key": "v3Path", "label": "v3Path (multi-hop: token,fee,token,...)", "inputType": "text" },
    { "key": "tickLower", "label": "tickLower (V3 mint; int24)", "inputType": "text" },
    { "key": "tickUpper", "label": "tickUpper (V3 mint; int24)", "inputType": "text" },
    { "key": "v3PositionTokenId", "label": "v3PositionTokenId (V3 NFT id)", "inputType": "text" },
    { "key": "v3Amount0Desired", "label": "v3Amount0Desired (increase; pool token0; max/balance OK)", "inputType": "text" },
    { "key": "v3Amount1Desired", "label": "v3Amount1Desired (increase; pool token1; max/balance OK)", "inputType": "text" },
    { "key": "v3Amount0Min", "label": "v3Amount0Min (increase/decrease slippage, token0 side)", "inputType": "text" },
    { "key": "v3Amount1Min", "label": "v3Amount1Min (increase/decrease slippage, token1 side)", "inputType": "text" },
    { "key": "v3Liquidity", "label": "v3Liquidity (decrease; uint128 or max/balance = all)", "inputType": "text" },
    { "key": "v3Amount0Max", "label": "v3Amount0Max (collect; empty = max uint128)", "inputType": "text" },
    { "key": "v3Amount1Max", "label": "v3Amount1Max (collect; empty = max uint128)", "inputType": "text" },
    { "key": "sqrtPriceLimitX96", "label": "sqrtPriceLimitX96 (V3 swap; empty = 0)", "inputType": "text" },
    { "key": "swapRouterV3Address", "label": "V3 SwapRouter override (optional)", "inputType": "text", "hint": "Must match pinned address if set" },
    { "key": "positionManagerAddress", "label": "V3 NPM override (optional)", "inputType": "text", "hint": "Must match pinned address if set" },
    { "key": "tokenA", "label": "tokenA (V2 liquidity / V3 mint pair)", "inputType": "text" },
    { "key": "tokenB", "label": "tokenB (V2 liquidity / V3 mint pair)", "inputType": "text" },
    { "key": "amountADesired", "label": "amountADesired (tokenA / addLiquidityETH token; max/balance OK)", "inputType": "text" },
    { "key": "amountBDesired", "label": "amountBDesired (tokenB; max/balance OK for addLiquidity)", "inputType": "text" },
    { "key": "amountAMin", "label": "amountAMin / token min (remove / addLiquidityETH)", "inputType": "text" },
    { "key": "amountBMin", "label": "amountBMin / BNB min (remove / addLiquidityETH)", "inputType": "text" },
    { "key": "liquidity", "label": "liquidity (remove; uint256 or max/balance)", "inputType": "text" },
    { "key": "pid", "label": "Farm pid", "inputType": "text" },
    { "key": "routerAddress", "label": "Router override (optional)", "inputType": "text", "hint": "Must match pinned V2 router if set" },
    { "key": "masterChefAddress", "label": "MasterChef override (optional)", "inputType": "text" },
    { "key": "deadline", "label": "Deadline", "inputType": "text", "placeholder": "empty = +1200s; or unix sec; or seconds from now" },
    { "key": "waitConfirmations", "label": "Wait confirmations", "inputType": "number", "placeholder": "1" },
    { "key": "gasLimit", "label": "gasLimit (optional; default 1800000; min 21000)", "inputType": "text", "placeholder": "Leave empty for default" },
    { "key": "saveTxHashVariable", "label": "Save tx hash to variable", "inputType": "text" },
    { "key": "saveExplorerUrlVariable", "label": "Save explorer URL to variable", "inputType": "text" },
    { "key": "saveV3PositionTokenIdVariable", "label": "Save minted V3 position NFT id (v3PositionMint only)", "inputType": "text" },
    { "key": "infinityFee", "label": "infinityFee (uint24 — Infinity bin pool)", "inputType": "text" },
    { "key": "binStep", "label": "binStep (1–100)", "inputType": "text" },
    { "key": "infinityHooks", "label": "infinityHooks (optional)", "inputType": "text" },
    { "key": "infinityHooksRegistrationJson", "label": "infinityHooksRegistrationJson (optional)", "inputType": "text" },
    { "key": "binPoolManagerAddress", "label": "binPoolManagerAddress override (optional)", "inputType": "text" },
    { "key": "binPositionManagerAddress", "label": "binPositionManagerAddress override (optional)", "inputType": "text", "hint": "Must match pinned Infinity BinPositionManager if set" },
    { "key": "infiPoolInitialized", "label": "infiPoolInitialized (skip initializePool if true)", "inputType": "checkbox" },
    { "key": "infiLiquidityShape", "label": "infiLiquidityShape (Spot | Curve | BidAsk)", "inputType": "text" },
    { "key": "infiActiveIdDesired", "label": "infiActiveIdDesired (uint256)", "inputType": "text" },
    { "key": "infiIdSlippage", "label": "infiIdSlippage (uint256)", "inputType": "text" },
    { "key": "infiLowerBinId", "label": "infiLowerBinId", "inputType": "text" },
    { "key": "infiUpperBinId", "label": "infiUpperBinId", "inputType": "text" },
    { "key": "infiAmount0", "label": "infiAmount0 (uint128)", "inputType": "text" },
    { "key": "infiAmount1", "label": "infiAmount1 (uint128)", "inputType": "text" },
    { "key": "infiAmount0Max", "label": "infiAmount0Max (uint128)", "inputType": "text" },
    { "key": "infiAmount1Max", "label": "infiAmount1Max (uint128)", "inputType": "text" },
    { "key": "infiDeadline", "label": "infiDeadline (unix sec uint256)", "inputType": "text" },
    { "key": "infiModifyHookData", "label": "infiModifyHookData (hex; optional 0x; swap + add/remove)", "inputType": "text" },
    { "key": "infiSwapCurrencyIn", "label": "infiSwapCurrencyIn (multi-hop swap: input token 0x…; native = zero address)", "inputType": "text" },
    { "key": "infiBinPathJson", "label": "infiBinPathJson (multi-hop: JSON array of hops)", "inputType": "textarea", "rows": 4, "placeholder": "[{\"intermediateCurrency\":\"0x…\",\"infinityFee\":\"3000\",\"binStep\":\"10\"}]" },
    { "key": "infiSwapAmountIn", "label": "infiSwapAmountIn (uint128 — exact-in swap)", "inputType": "text" },
    { "key": "infiSwapAmountOutMin", "label": "infiSwapAmountOutMin (exact-in swap; uint128; 0 = no min)", "inputType": "text" },
    { "key": "infiSwapAmountOut", "label": "infiSwapAmountOut (exact-out swap; uint128)", "inputType": "text" },
    { "key": "infiSwapAmountInMax", "label": "infiSwapAmountInMax (exact-out swap; max input uint128)", "inputType": "text" },
    { "key": "infiSwapZeroForOne", "label": "infiSwapZeroForOne (swap currency0 → currency1)", "inputType": "checkbox" },
    { "key": "infiPayload", "label": "infiPayload (modifyLiquidities inner bytes hex)", "inputType": "text" },
    { "key": "infiAmount0Min", "label": "infiAmount0Min (remove)", "inputType": "text" },
    { "key": "infiAmount1Min", "label": "infiAmount1Min (remove)", "inputType": "text" },
    { "key": "infiRemoveBinIds", "label": "infiRemoveBinIds (comma-separated uint24)", "inputType": "text" },
    { "key": "infiRemoveShares", "label": "infiRemoveShares (comma-separated uint256)", "inputType": "text" },
    { "key": "infiFarmClaimTs", "label": "infiFarmClaimTs (optional unix sec for API path)", "inputType": "text" },
    { "key": "infiFarmClaimSkipIfNoRewards", "label": "infiFarmClaimSkipIfNoRewards (no tx if API has nothing to claim)", "inputType": "checkbox" },
    { "key": "distributorAddress", "label": "distributorAddress override (infiFarmClaim; optional)", "inputType": "text", "hint": "Must match pinned Infinity Farming Distributor if set" },
    { "key": "permit2Spender", "label": "permit2Spender (BinPositionManager)", "inputType": "text" },
    { "key": "permit2Amount", "label": "permit2Amount (uint160)", "inputType": "text" },
    { "key": "permit2Expiration", "label": "permit2Expiration (uint48)", "inputType": "text" },
    { "key": "saveInfiPositionTokenIdVariable", "label": "Save minted Infinity Bin NFT id (infiBinAddLiquidity)", "inputType": "text" },
    { "key": "saveInfiFarmClaimOutcomeVariable", "label": "Save infiFarmClaim outcome JSON (skipped + skipReason or txHash + explorerUrl)", "inputType": "text" }
  ]
}
