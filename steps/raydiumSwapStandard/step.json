{
  "id": "raydiumSwapStandard",
  "label": "Raydium swap (Standard AMM)",
  "category": "data",
  "description": "Single-hop swap on a Raydium **Standard** pool (OpenBook-linked AMM). `inputMint` and `outputMint` must be the pool's two mints. `amountInRaw` is the exact input in smallest units; min output follows `slippageBps`. WSOL uses native SOL balance flags. Not CLMM/CPMM. Rebuild: npm run build:raydium.",
  "defaultAction": {
    "type": "raydiumSwapStandard",
    "runIf": "",
    "poolId": "",
    "inputMint": "",
    "outputMint": "",
    "amountInRaw": "",
    "slippageBps": 50,
    "cluster": "mainnet-beta",
    "rpcUrl": "",
    "skipSimulation": false,
    "skipPreflight": false,
    "saveSignatureVariable": "solanaTxSignature",
    "saveExplorerUrlVariable": "solanaExplorerUrl",
    "saveAmountOutMinVariable": "",
    "saveAmountOutExpectedVariable": ""
  },
  "formSchema": [
    {
      "key": "runIf",
      "label": "Run only if (optional)",
      "inputType": "text"
    },
    {
      "key": "poolId",
      "label": "Pool id (base58)",
      "inputType": "poolSearch",
      "poolSearchMessage": "CFS_RAYDIUM_POOL_SEARCH",
      "poolSearchDeps": [
        "inputMint",
        "outputMint"
      ],
      "placeholder": "Paste pool ID or search by token pair"
    },
    {
      "key": "inputMint",
      "label": "Input mint",
      "inputType": "text"
    },
    {
      "key": "outputMint",
      "label": "Output mint",
      "inputType": "text"
    },
    {
      "key": "amountInRaw",
      "label": "Amount in (raw)",
      "inputType": "text"
    },
    {
      "key": "slippageBps",
      "label": "Slippage (basis points)",
      "inputType": "number"
    },
    {
      "key": "cluster",
      "label": "Cluster",
      "inputType": "select",
      "options": [
        {
          "value": "mainnet-beta",
          "label": "mainnet-beta"
        },
        {
          "value": "devnet",
          "label": "devnet"
        }
      ]
    },
    {
      "key": "rpcUrl",
      "label": "RPC override",
      "inputType": "text"
    },
    {
      "key": "skipSimulation",
      "label": "Skip simulation",
      "inputType": "checkbox"
    },
    {
      "key": "skipPreflight",
      "label": "Skip preflight",
      "inputType": "checkbox"
    },
    {
      "key": "saveSignatureVariable",
      "label": "Save signature variable",
      "inputType": "text"
    },
    {
      "key": "saveExplorerUrlVariable",
      "label": "Save explorer URL variable",
      "inputType": "text"
    },
    {
      "key": "saveAmountOutMinVariable",
      "label": "Save min out raw (optional)",
      "inputType": "text"
    },
    {
      "key": "saveAmountOutExpectedVariable",
      "label": "Save expected out raw (optional)",
      "inputType": "text"
    }
  ]
}