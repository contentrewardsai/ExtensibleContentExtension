{
  "id": "solanaReadMint",
  "label": "Solana read mint",
  "category": "data",
  "description": "Read-only RPC: SPL mint account fields (decimals, supply, initialized, mint authority, freeze authority). Optional includeMetaplexMetadata runs getMint and Metaplex PDA read in parallel. Optional fetchMetaplexUriBody (requires includeMetaplexMetadata) HTTPS-fetches uri like solanaReadMetaplexMetadata. No wallet unlock.",
  "defaultAction": {
    "type": "solanaReadMint",
    "runIf": "",
    "mint": "",
    "tokenProgram": "token",
    "cluster": "mainnet-beta",
    "rpcUrl": "",
    "includeMetaplexMetadata": false,
    "fetchMetaplexUriBody": false,
    "metaplexIpfsGateway": "",
    "metaplexIpnsGateway": "",
    "metaplexArweaveGateway": "",
    "saveDecimalsVariable": "solanaMintDecimals",
    "saveSupplyVariable": "solanaMintSupply",
    "saveMintInitializedVariable": "solanaMintInitialized",
    "saveMintAuthorityVariable": "solanaMintMintAuthority",
    "saveFreezeAuthorityVariable": "solanaMintFreezeAuthority",
    "saveMetaplexMetadataFoundVariable": "solanaMintMetaplexFound",
    "saveMetaplexMetadataAccountVariable": "solanaMintMetaplexAccount",
    "saveMetaplexNameVariable": "solanaMintMetaplexName",
    "saveMetaplexSymbolVariable": "solanaMintMetaplexSymbol",
    "saveMetaplexUriVariable": "solanaMintMetaplexUri",
    "saveMetaplexUpdateAuthorityVariable": "solanaMintMetaplexUpdateAuthority",
    "saveUriFetchOkVariable": "",
    "saveUriResolvedForFetchVariable": "",
    "saveUriBodyVariable": "",
    "saveUriFetchErrorVariable": "",
    "saveUriBodyTruncatedVariable": ""
  },
  "formSchema": [
    { "key": "runIf", "label": "Run only if (optional)", "inputType": "text" },
    { "key": "mint", "label": "Mint", "inputType": "text" },
    { "key": "tokenProgram", "label": "Token program", "inputType": "select", "options": [
      { "value": "token", "label": "SPL Token" },
      { "value": "token-2022", "label": "Token-2022" }
    ] },
    { "key": "cluster", "label": "Cluster", "inputType": "select", "options": [
      { "value": "mainnet-beta", "label": "mainnet-beta" },
      { "value": "devnet", "label": "devnet" }
    ] },
    { "key": "rpcUrl", "label": "RPC URL override (optional)", "inputType": "text" },
    { "key": "includeMetaplexMetadata", "label": "Also read Metaplex PDA (parallel with mint)", "inputType": "checkbox" },
    { "key": "fetchMetaplexUriBody", "label": "HTTPS-fetch uri body (requires Metaplex on)", "inputType": "checkbox" },
    { "key": "metaplexIpfsGateway", "label": "IPFS gateway base (optional)", "inputType": "text" },
    { "key": "metaplexIpnsGateway", "label": "IPNS gateway base (optional)", "inputType": "text" },
    { "key": "metaplexArweaveGateway", "label": "Arweave gateway base (optional)", "inputType": "text" },
    { "key": "saveDecimalsVariable", "label": "Save decimals", "inputType": "text" },
    { "key": "saveSupplyVariable", "label": "Save supply (raw string)", "inputType": "text" },
    { "key": "saveMintInitializedVariable", "label": "Save initialized true/false", "inputType": "text" },
    { "key": "saveMintAuthorityVariable", "label": "Save mint authority (empty if none)", "inputType": "text" },
    { "key": "saveFreezeAuthorityVariable", "label": "Save freeze authority (empty if none)", "inputType": "text" },
    { "key": "saveMetaplexMetadataFoundVariable", "label": "Save Metaplex found (when include on)", "inputType": "text" },
    { "key": "saveMetaplexMetadataAccountVariable", "label": "Save Metaplex metadata account", "inputType": "text" },
    { "key": "saveMetaplexNameVariable", "label": "Save Metaplex on-chain name", "inputType": "text" },
    { "key": "saveMetaplexSymbolVariable", "label": "Save Metaplex on-chain symbol", "inputType": "text" },
    { "key": "saveMetaplexUriVariable", "label": "Save Metaplex on-chain uri", "inputType": "text" },
    { "key": "saveMetaplexUpdateAuthorityVariable", "label": "Save Metaplex update authority", "inputType": "text" },
    { "key": "saveUriFetchOkVariable", "label": "Save uri fetch ok (when fetch on)", "inputType": "text" },
    { "key": "saveUriResolvedForFetchVariable", "label": "Save resolved fetch URL", "inputType": "text" },
    { "key": "saveUriBodyVariable", "label": "Save uri body", "inputType": "text" },
    { "key": "saveUriFetchErrorVariable", "label": "Save uri fetch error", "inputType": "text" },
    { "key": "saveUriBodyTruncatedVariable", "label": "Save uri body truncated", "inputType": "text" }
  ]
}
