{
  "id": "meteoraDlmmRemoveLiquidity",
  "label": "Meteora DLMM remove liquidity",
  "category": "data",
  "description": "Remove liquidity from an existing **DLMM position** on [Meteora](https://www.meteora.ag/pools). **removeBps** is basis points of liquidity to remove (default 10000 = 100%). **shouldClaimAndClose** (default on) claims fees/rewards and closes the position when removing 100%. May send multiple transactions; the step saves the **last** signature. Rebuild: `npm run build:meteora`.",
  "defaultAction": {
    "type": "meteoraDlmmRemoveLiquidity",
    "runIf": "",
    "lbPair": "",
    "position": "",
    "removeBps": 10000,
    "shouldClaimAndClose": true,
    "cluster": "mainnet-beta",
    "rpcUrl": "",
    "skipSimulation": false,
    "skipPreflight": false,
    "saveSignatureVariable": "solanaTxSignature",
    "saveExplorerUrlVariable": "solanaExplorerUrl"
  },
  "formSchema": [
    {
      "key": "runIf",
      "label": "Run only if (optional)",
      "inputType": "text"
    },
    {
      "key": "lbPair",
      "label": "LB pair (pool) address",
      "inputType": "poolSearch",
      "poolSearchMessage": "CFS_METEORA_POOL_SEARCH",
      "poolSearchDeps": [],
      "placeholder": "Paste lbPair address or search"
    },
    {
      "key": "position",
      "label": "Position address",
      "inputType": "text"
    },
    {
      "key": "removeBps",
      "label": "Remove (basis points, 10000 = 100%)",
      "inputType": "number"
    },
    {
      "key": "shouldClaimAndClose",
      "label": "Claim and close (full remove)",
      "inputType": "checkbox"
    },
    {
      "key": "cluster",
      "label": "Cluster",
      "inputType": "select",
      "options": [
        {
          "value": "mainnet-beta",
          "label": "mainnet-beta"
        },
        {
          "value": "devnet",
          "label": "devnet"
        }
      ]
    },
    {
      "key": "rpcUrl",
      "label": "RPC override",
      "inputType": "text"
    },
    {
      "key": "skipSimulation",
      "label": "Skip simulation",
      "inputType": "checkbox"
    },
    {
      "key": "skipPreflight",
      "label": "Skip preflight",
      "inputType": "checkbox"
    },
    {
      "key": "saveSignatureVariable",
      "label": "Save last tx signature",
      "inputType": "text"
    },
    {
      "key": "saveExplorerUrlVariable",
      "label": "Save explorer URL",
      "inputType": "text"
    }
  ]
}
