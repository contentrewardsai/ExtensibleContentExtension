{
  "id": "raydiumClmmHarvestLockPosition",
  "label": "Raydium CLMM harvest lock position",
  "category": "data",
  "description": "Harvests rewards for a **Raydium CLMM locked** position owned by the automation wallet. Pass **lockNftMint** (the **lock** NFT mint). The background resolves lock metadata via `getOwnerLockedPositionInfo` then calls `harvestLockPosition`. Token-2022 edge cases follow the Raydium SDK. For unlocked positions use **raydiumClmmCollectReward** / **raydiumClmmCollectRewards** instead.",
  "defaultAction": {
    "type": "raydiumClmmHarvestLockPosition",
    "runIf": "",
    "lockNftMint": "",
    "cluster": "mainnet-beta",
    "rpcUrl": "",
    "skipSimulation": false,
    "skipPreflight": false,
    "saveSignatureVariable": "solanaTxSignature",
    "saveExplorerUrlVariable": "solanaExplorerUrl"
  },
  "formSchema": [
    { "key": "runIf", "label": "Run only if (optional)", "inputType": "text" },
    { "key": "lockNftMint", "label": "Lock NFT mint", "inputType": "text" },
    { "key": "cluster", "label": "Cluster", "inputType": "select", "options": [
      { "value": "mainnet-beta", "label": "mainnet-beta" },
      { "value": "devnet", "label": "devnet" }
    ] },
    { "key": "rpcUrl", "label": "RPC override", "inputType": "text" },
    { "key": "skipSimulation", "label": "Skip simulation", "inputType": "checkbox" },
    { "key": "skipPreflight", "label": "Skip preflight", "inputType": "checkbox" },
    { "key": "saveSignatureVariable", "label": "Save signature variable", "inputType": "text" },
    { "key": "saveExplorerUrlVariable", "label": "Save explorer URL variable", "inputType": "text" }
  ]
}
