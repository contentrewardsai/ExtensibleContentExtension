{
  "id": "jupiterDCA",
  "label": "Jupiter DCA (Recurring buy)",
  "category": "data",
  "description": "Create a Dollar-Cost Averaging order via Jupiter Recurring API. Automatically buys outputMint at regular intervals using inputMint. Requires Solana automation wallet. Total amount, per-cycle amount, and cycle interval are configurable.",
  "defaultAction": {
    "type": "jupiterDCA",
    "runIf": "",
    "inputMint": "So11111111111111111111111111111111111111112",
    "outputMint": "",
    "inAmount": "",
    "inAmountPerCycle": "",
    "cycleSecondsApart": "86400",
    "minOutAmountPerCycle": "",
    "maxOutAmountPerCycle": "",
    "startAt": "",
    "cluster": "mainnet-beta",
    "rpcUrl": "",
    "saveDcaOrderKeyVariable": "dcaOrderKey",
    "saveSignatureVariable": "solanaTxSignature",
    "saveExplorerUrlVariable": "solanaExplorerUrl"
  },
  "formSchema": [
    { "key": "runIf", "label": "Run only if (optional)", "inputType": "text" },
    { "key": "inputMint", "label": "Input mint (spend)", "inputType": "text", "placeholder": "SOL wrapped mint" },
    { "key": "outputMint", "label": "Output mint (buy)", "inputType": "text" },
    { "key": "inAmount", "label": "Total amount (raw, smallest units)", "inputType": "text", "placeholder": "Total to invest over all cycles" },
    { "key": "inAmountPerCycle", "label": "Amount per cycle (raw)", "inputType": "text" },
    { "key": "cycleSecondsApart", "label": "Seconds between cycles", "inputType": "text", "placeholder": "86400 = daily" },
    { "key": "minOutAmountPerCycle", "label": "Min output per cycle (optional)", "inputType": "text" },
    { "key": "maxOutAmountPerCycle", "label": "Max output per cycle (optional)", "inputType": "text" },
    { "key": "startAt", "label": "Start at (Unix timestamp, optional)", "inputType": "text" },
    { "key": "cluster", "label": "Cluster", "inputType": "select", "options": [
      { "value": "mainnet-beta", "label": "mainnet-beta" },
      { "value": "devnet", "label": "devnet" }
    ] },
    { "key": "rpcUrl", "label": "RPC URL override (optional)", "inputType": "text" },
    { "key": "saveDcaOrderKeyVariable", "label": "Save DCA order key to variable", "inputType": "text" },
    { "key": "saveSignatureVariable", "label": "Save tx signature to variable", "inputType": "text" },
    { "key": "saveExplorerUrlVariable", "label": "Save explorer URL to variable", "inputType": "text" }
  ]
}
