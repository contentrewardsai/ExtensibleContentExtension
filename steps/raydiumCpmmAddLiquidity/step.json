{
  "id": "raydiumCpmmAddLiquidity",
  "label": "Raydium add liquidity (CPMM)",
  "category": "data",
  "description": "Add liquidity to a Raydium **CPMM** (cp-swap) pool. `fixedSide` **a** or **b** is the mint you deposit at a fixed raw amount; the SDK pairs the other leg with `slippageBps`. **Not** Standard OpenBook AMM or CLMM — use **raydiumAddLiquidity** or **raydiumClmmOpenPosition**. Rebuild: npm run build:raydium.",
  "defaultAction": {
    "type": "raydiumCpmmAddLiquidity",
    "runIf": "",
    "poolId": "",
    "fixedSide": "a",
    "amountInRaw": "",
    "slippageBps": 50,
    "cluster": "mainnet-beta",
    "rpcUrl": "",
    "skipSimulation": false,
    "skipPreflight": false,
    "saveSignatureVariable": "solanaTxSignature",
    "saveExplorerUrlVariable": "solanaExplorerUrl"
  },
  "formSchema": [
    { "key": "runIf", "label": "Run only if (optional)", "inputType": "text" },
    { "key": "poolId", "label": "CPMM pool id (base58)", "inputType": "text" },
    { "key": "fixedSide", "label": "Fixed side", "inputType": "select", "options": [
      { "value": "a", "label": "a (mint A)" },
      { "value": "b", "label": "b (mint B)" }
    ] },
    { "key": "amountInRaw", "label": "Amount in (raw, fixed side)", "inputType": "text" },
    { "key": "slippageBps", "label": "Slippage (basis points)", "inputType": "number" },
    { "key": "cluster", "label": "Cluster", "inputType": "select", "options": [
      { "value": "mainnet-beta", "label": "mainnet-beta" },
      { "value": "devnet", "label": "devnet" }
    ] },
    { "key": "rpcUrl", "label": "RPC override", "inputType": "text" },
    { "key": "skipSimulation", "label": "Skip simulation", "inputType": "checkbox" },
    { "key": "skipPreflight", "label": "Skip preflight", "inputType": "checkbox" },
    { "key": "saveSignatureVariable", "label": "Save signature variable", "inputType": "text" },
    { "key": "saveExplorerUrlVariable", "label": "Save explorer URL variable", "inputType": "text" }
  ]
}
