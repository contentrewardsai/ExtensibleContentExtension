{
  "id": "meteoraDlmmClaimRewards",
  "label": "Meteora DLMM claim rewards",
  "category": "data",
  "description": "Claim **swap fees and liquidity-mining style rewards** for a DLMM position via `claimAllRewardsByPosition` ([Meteora DLMM SDK](https://www.npmjs.com/package/@meteora-ag/dlmm)). If there is nothing to claim, the step succeeds with an empty signature. Multiple txs possible; **last** signature is saved. Pools: [meteora.ag/pools](https://www.meteora.ag/pools). Rebuild: `npm run build:meteora`.",
  "defaultAction": {
    "type": "meteoraDlmmClaimRewards",
    "runIf": "",
    "lbPair": "",
    "position": "",
    "cluster": "mainnet-beta",
    "rpcUrl": "",
    "skipSimulation": false,
    "skipPreflight": false,
    "saveSignatureVariable": "solanaTxSignature",
    "saveExplorerUrlVariable": "solanaExplorerUrl"
  },
  "formSchema": [
    { "key": "runIf", "label": "Run only if (optional)", "inputType": "text" },
    { "key": "lbPair", "label": "LB pair (pool) address", "inputType": "text" },
    { "key": "position", "label": "Position address", "inputType": "text" },
    { "key": "cluster", "label": "Cluster", "inputType": "select", "options": [
      { "value": "mainnet-beta", "label": "mainnet-beta" },
      { "value": "devnet", "label": "devnet" }
    ] },
    { "key": "rpcUrl", "label": "RPC override", "inputType": "text" },
    { "key": "skipSimulation", "label": "Skip simulation", "inputType": "checkbox" },
    { "key": "skipPreflight", "label": "Skip preflight", "inputType": "checkbox" },
    { "key": "saveSignatureVariable", "label": "Save last tx signature", "inputType": "text" },
    { "key": "saveExplorerUrlVariable", "label": "Save explorer URL", "inputType": "text" }
  ]
}
