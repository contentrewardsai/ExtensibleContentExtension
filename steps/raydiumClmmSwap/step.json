{
  "id": "raydiumClmmSwap",
  "label": "Raydium swap (CLMM)",
  "category": "data",
  "description": "Single-hop swap on a Raydium **CLMM** (concentrated) pool. `inputMint` and `outputMint` must be the pool's two mints. `amountInRaw` is exact input in smallest units. Min output defaults from `slippageBps` via on-chain quote (`PoolUtils.computeAmountOutFormat`); set optional `amountOutMinRaw` to override the on-chain min (e.g. from Raydium UI). Not Standard AMM / CPMM. Rebuild: npm run build:raydium.",
  "defaultAction": {
    "type": "raydiumClmmSwap",
    "runIf": "",
    "poolId": "",
    "inputMint": "",
    "outputMint": "",
    "amountInRaw": "",
    "slippageBps": 50,
    "amountOutMinRaw": "",
    "cluster": "mainnet-beta",
    "rpcUrl": "",
    "skipSimulation": false,
    "skipPreflight": false,
    "saveSignatureVariable": "solanaTxSignature",
    "saveExplorerUrlVariable": "solanaExplorerUrl",
    "saveAmountOutMinVariable": "",
    "saveAmountOutExpectedVariable": ""
  },
  "formSchema": [
    { "key": "runIf", "label": "Run only if (optional)", "inputType": "text" },
    { "key": "poolId", "label": "CLMM pool id (base58)", "inputType": "text" },
    { "key": "inputMint", "label": "Input mint", "inputType": "text" },
    { "key": "outputMint", "label": "Output mint", "inputType": "text" },
    { "key": "amountInRaw", "label": "Amount in (raw)", "inputType": "text" },
    { "key": "slippageBps", "label": "Slippage (basis points)", "inputType": "number" },
    { "key": "amountOutMinRaw", "label": "Min out raw (optional override)", "inputType": "text" },
    { "key": "cluster", "label": "Cluster", "inputType": "select", "options": [
      { "value": "mainnet-beta", "label": "mainnet-beta" },
      { "value": "devnet", "label": "devnet" }
    ] },
    { "key": "rpcUrl", "label": "RPC override", "inputType": "text" },
    { "key": "skipSimulation", "label": "Skip simulation", "inputType": "checkbox" },
    { "key": "skipPreflight", "label": "Skip preflight", "inputType": "checkbox" },
    { "key": "saveSignatureVariable", "label": "Save signature variable", "inputType": "text" },
    { "key": "saveExplorerUrlVariable", "label": "Save explorer URL variable", "inputType": "text" },
    { "key": "saveAmountOutMinVariable", "label": "Save min out raw (optional)", "inputType": "text" },
    { "key": "saveAmountOutExpectedVariable", "label": "Save expected out raw (optional)", "inputType": "text" }
  ]
}
