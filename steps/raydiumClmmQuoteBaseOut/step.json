{
  "id": "raydiumClmmQuoteBaseOut",
  "label": "Raydium CLMM quote (exact out)",
  "category": "data",
  "description": "Read-only **quote** for a CLMM swap with exact output (`CFS_RAYDIUM_CLMM_QUOTE_BASE_OUT`). No transaction. Saves optional row vars for expected/max input and tick-account count; pair with **raydiumClmmSwapBaseOut**. Wallet must be unlocked. Rebuild: npm run build:raydium.",
  "defaultAction": {
    "type": "raydiumClmmQuoteBaseOut",
    "runIf": "",
    "poolId": "",
    "inputMint": "",
    "outputMint": "",
    "amountOutRaw": "",
    "slippageBps": 50,
    "amountInMaxRaw": "",
    "cluster": "mainnet-beta",
    "rpcUrl": "",
    "saveAmountInMaxVariable": "clmmQuoteMaxInRaw",
    "saveAmountInExpectedVariable": "clmmQuoteExpectedInRaw",
    "saveAmountOutVariable": "",
    "saveRemainingAccountsCountVariable": ""
  },
  "formSchema": [
    { "key": "runIf", "label": "Run only if (optional)", "inputType": "text" },
    { "key": "poolId", "label": "CLMM pool id (base58)", "inputType": "text" },
    { "key": "inputMint", "label": "Input mint", "inputType": "text" },
    { "key": "outputMint", "label": "Output mint", "inputType": "text" },
    { "key": "amountOutRaw", "label": "Amount out (raw, exact)", "inputType": "text" },
    { "key": "slippageBps", "label": "Slippage (basis points)", "inputType": "number" },
    { "key": "amountInMaxRaw", "label": "Max in raw (optional quote hint)", "inputType": "text" },
    { "key": "cluster", "label": "Cluster", "inputType": "select", "options": [
      { "value": "mainnet-beta", "label": "mainnet-beta" },
      { "value": "devnet", "label": "devnet" }
    ] },
    { "key": "rpcUrl", "label": "RPC override", "inputType": "text" },
    { "key": "saveAmountInMaxVariable", "label": "Save max in raw (row key)", "inputType": "text" },
    { "key": "saveAmountInExpectedVariable", "label": "Save expected in raw (row key)", "inputType": "text" },
    { "key": "saveAmountOutVariable", "label": "Save amount out raw (optional echo)", "inputType": "text" },
    { "key": "saveRemainingAccountsCountVariable", "label": "Save remaining accounts count (optional)", "inputType": "text" }
  ]
}
