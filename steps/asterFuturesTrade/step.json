{
  "id": "asterFuturesTrade",
  "label": "Aster futures (trade)",
  "category": "data",
  "description": "Signed TRADE: place/cancel, batch cancel, countdown cancel-all, leverage, margin type, isolated position margin, hedge/multi-asset mode, batch place, replace SL/TP, cancel SL/TP by scan, listen key. Optional dryRun and exchange filter validation. Enable trading in Settings.",
  "defaultAction": {
    "type": "asterFuturesTrade",
    "runIf": "",
    "operation": "placeOrder",
    "recvWindow": "",
    "symbol": "",
    "side": "",
    "positionSide": "",
    "orderType": "MARKET",
    "timeInForce": "GTC",
    "quantity": "",
    "price": "",
    "reduceOnly": "",
    "newClientOrderId": "",
    "stopPrice": "",
    "closePosition": "",
    "activationPrice": "",
    "callbackRate": "",
    "workingType": "",
    "priceProtect": "",
    "newOrderRespType": "",
    "orderId": "",
    "origClientOrderId": "",
    "leverage": "",
    "marginType": "",
    "batchOrders": "",
    "dryRun": "",
    "validateExchangeFilters": "",
    "roundToExchangeFilters": "",
    "countdownTime": "",
    "orderIdList": "",
    "origClientOrderIdList": "",
    "dualSidePosition": "",
    "multiAssetsMargin": "",
    "positionMarginAmount": "",
    "positionMarginType": "",
    "clientOrderIdPrefix": "",
    "listenKey": "",
    "saveResultVariable": "asterTradeResult"
  },
  "formSchema": [
    { "key": "runIf", "label": "Run only if (optional)", "inputType": "text", "placeholder": "{{var}} or variable name" },
    {
      "key": "operation",
      "label": "Operation",
      "inputType": "select",
      "options": [
        { "value": "placeOrder", "label": "placeOrder" },
        { "value": "cancelOrder", "label": "cancelOrder" },
        { "value": "cancelAllOpen", "label": "cancelAllOpen (symbol)" },
        { "value": "cancelBatch", "label": "cancelBatch (symbol + orderIdList or origClientOrderIdList JSON)" },
        { "value": "countdownCancelAll", "label": "countdownCancelAll (symbol + countdownTime ms)" },
        { "value": "cancelStopLoss", "label": "cancelStopLoss (symbol; optional clientOrderIdPrefix)" },
        { "value": "cancelTakeProfit", "label": "cancelTakeProfit (symbol; optional clientOrderIdPrefix)" },
        { "value": "setLeverage", "label": "setLeverage (symbol + leverage)" },
        { "value": "setMarginType", "label": "setMarginType (symbol + ISOLATED/CROSSED)" },
        { "value": "setPositionMode", "label": "setPositionMode (dualSidePosition true/false)" },
        { "value": "setMultiAssetsMargin", "label": "setMultiAssetsMargin (multiAssetsMargin true/false)" },
        { "value": "positionMargin", "label": "positionMargin (symbol + positionMarginAmount + positionMarginType 1|2)" },
        { "value": "batchOrders", "label": "batchOrders (batchOrders JSON array string)" },
        { "value": "replaceStopLoss", "label": "replaceStopLoss (cancel + place SL)" },
        { "value": "replaceTakeProfit", "label": "replaceTakeProfit (cancel + place TP)" },
        { "value": "listenKeyCreate", "label": "listenKeyCreate" },
        { "value": "listenKeyKeepalive", "label": "listenKeyKeepalive" },
        { "value": "listenKeyClose", "label": "listenKeyClose" }
      ]
    },
    { "key": "recvWindow", "label": "recvWindow", "inputType": "text" },
    { "key": "listenKey", "label": "listenKey (listenKeyKeepalive / listenKeyClose)", "inputType": "text" },
    { "key": "symbol", "label": "symbol", "inputType": "text" },
    { "key": "side", "label": "side (BUY/SELL)", "inputType": "text" },
    { "key": "positionSide", "label": "positionSide (LONG/SHORT/BOTH)", "inputType": "text" },
    { "key": "orderType", "label": "orderType (LIMIT/MARKET/STOP/…)", "inputType": "text" },
    { "key": "timeInForce", "label": "timeInForce", "inputType": "text" },
    { "key": "quantity", "label": "quantity", "inputType": "text" },
    { "key": "price", "label": "price", "inputType": "text" },
    { "key": "reduceOnly", "label": "reduceOnly (true/false)", "inputType": "text" },
    { "key": "newClientOrderId", "label": "newClientOrderId", "inputType": "text" },
    { "key": "stopPrice", "label": "stopPrice", "inputType": "text" },
    { "key": "closePosition", "label": "closePosition", "inputType": "text" },
    { "key": "activationPrice", "label": "activationPrice (trailing)", "inputType": "text" },
    { "key": "callbackRate", "label": "callbackRate (trailing)", "inputType": "text" },
    { "key": "workingType", "label": "workingType", "inputType": "text" },
    { "key": "priceProtect", "label": "priceProtect", "inputType": "text" },
    { "key": "newOrderRespType", "label": "newOrderRespType (ACK/RESULT)", "inputType": "text" },
    { "key": "orderId", "label": "orderId (cancel / replace cancel leg)", "inputType": "text" },
    { "key": "origClientOrderId", "label": "origClientOrderId", "inputType": "text" },
    { "key": "leverage", "label": "leverage (integer)", "inputType": "text" },
    { "key": "marginType", "label": "marginType", "inputType": "text" },
    { "key": "batchOrders", "label": "batchOrders (JSON array of order objects)", "inputType": "textarea" },
    { "key": "dryRun", "label": "dryRun (placeOrder: true = validate only)", "inputType": "text" },
    { "key": "validateExchangeFilters", "label": "validateExchangeFilters (placeOrder/replace: true)", "inputType": "text" },
    { "key": "roundToExchangeFilters", "label": "roundToExchangeFilters (place/batch/replace: lot + tick)", "inputType": "text" },
    { "key": "countdownTime", "label": "countdownTime (countdownCancelAll, ms)", "inputType": "text" },
    { "key": "orderIdList", "label": "orderIdList (cancelBatch JSON e.g. [1,2])", "inputType": "text" },
    { "key": "origClientOrderIdList", "label": "origClientOrderIdList (cancelBatch JSON strings)", "inputType": "text" },
    { "key": "dualSidePosition", "label": "dualSidePosition (setPositionMode: true/false)", "inputType": "text" },
    { "key": "multiAssetsMargin", "label": "multiAssetsMargin (setMultiAssetsMargin: true/false)", "inputType": "text" },
    { "key": "positionMarginAmount", "label": "positionMarginAmount (positionMargin)", "inputType": "text" },
    { "key": "positionMarginType", "label": "positionMarginType (1 add / 2 reduce)", "inputType": "text" },
    { "key": "clientOrderIdPrefix", "label": "clientOrderIdPrefix (cancel SL/TP scan)", "inputType": "text" },
    { "key": "saveResultVariable", "label": "Save JSON result to variable", "inputType": "text" }
  ]
}
