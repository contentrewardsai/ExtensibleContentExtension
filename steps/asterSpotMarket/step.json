{
  "id": "asterSpotMarket",
  "label": "Aster spot (public)",
  "category": "data",
  "description": "Public Aster spot REST on sapi.asterdex.com (/api/v3): ping, time, exchangeInfo, symbolMeta (cached filters), depth, trades, aggTrades, klines, avgPrice, tickers. No API key.",
  "defaultAction": {
    "type": "asterSpotMarket",
    "runIf": "",
    "operation": "ping",
    "symbol": "",
    "limit": "",
    "interval": "1h",
    "fromId": "",
    "startTime": "",
    "endTime": "",
    "saveResultVariable": "asterSpotMarketResult"
  },
  "formSchema": [
    { "key": "runIf", "label": "Run only if (optional)", "inputType": "text", "placeholder": "{{var}} or variable name" },
    {
      "key": "operation",
      "label": "Operation",
      "inputType": "select",
      "options": [
        { "value": "ping", "label": "ping" },
        { "value": "time", "label": "time (server ms)" },
        { "value": "exchangeInfo", "label": "exchangeInfo (optional symbol filter)" },
        { "value": "symbolMeta", "label": "symbolMeta (symbol → filters, cached exchangeInfo)" },
        { "value": "depth", "label": "depth (symbol + optional limit)" },
        { "value": "trades", "label": "trades (symbol + optional limit)" },
        { "value": "aggTrades", "label": "aggTrades (symbol)" },
        { "value": "klines", "label": "klines (symbol + interval)" },
        { "value": "avgPrice", "label": "avgPrice (symbol)" },
        { "value": "ticker24hr", "label": "ticker24hr (symbol required)" },
        { "value": "tickerPrice", "label": "tickerPrice (optional symbol)" },
        { "value": "bookTicker", "label": "bookTicker (optional symbol)" }
      ]
    },
    { "key": "symbol", "label": "symbol (e.g. BTCUSDT)", "inputType": "text" },
    { "key": "limit", "label": "limit", "inputType": "text" },
    { "key": "interval", "label": "interval (klines: 1m,1h,1d,…)", "inputType": "text" },
    { "key": "fromId", "label": "fromId (trades / aggTrades)", "inputType": "text" },
    { "key": "startTime", "label": "startTime (ms)", "inputType": "text" },
    { "key": "endTime", "label": "endTime (ms)", "inputType": "text" },
    { "key": "saveResultVariable", "label": "Save JSON result to variable", "inputType": "text" }
  ]
}
