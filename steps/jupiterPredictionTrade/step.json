      { "value": "false", "label": "NO" }
    ] },
    { "key": "amount", "label": "Amount (USDC micro units, e.g. 1000000 = $1)", "inputType": "text" },
    { "key": "limitPrice", "label": "Limit price (micro USD, optional)", "inputType": "text" },
    { "key": "positionPubkey", "label": "Position pubkey (for close/claim)", "inputType": "text" },
    { "key": "saveSignatureVariable", "label": "Save tx signature to variable", "inputType": "text" },
    { "key": "saveExplorerUrlVariable", "label": "Save explorer URL to variable", "inputType": "text" }
  ]
}
