{
  "id": "asterSpotAccount",
  "label": "Aster spot (account)",
  "category": "data",
  "description": "Signed spot USER_DATA on sapi.asterdex.com: account, orders, trades, user stream, futuresTransfer (spot↔USDT-M margin, Binance-style /sapi/v1/futures/transfer). Same keys as futures in Settings.",
  "defaultAction": {
    "type": "asterSpotAccount",
    "runIf": "",
    "operation": "account",
    "recvWindow": "",
    "symbol": "",
    "orderId": "",
    "origClientOrderId": "",
    "startTime": "",
    "endTime": "",
    "limit": "",
    "fromId": "",
    "listenKey": "",
    "wsStreamBase": "",
    "createListenKey": "",
    "transferAsset": "",
    "transferAmount": "",
    "futuresTransferType": "",
    "transferHistoryAsset": "",
    "transferHistoryPage": "",
    "transferHistorySize": "",
    "saveResultVariable": "asterSpotAccountResult"
  },
  "formSchema": [
    { "key": "runIf", "label": "Run only if (optional)", "inputType": "text", "placeholder": "{{var}} or variable name" },
    {
      "key": "operation",
      "label": "Operation",
      "inputType": "select",
      "options": [
        { "value": "account", "label": "account (balances + permissions)" },
        { "value": "openOrders", "label": "openOrders (optional symbol)" },
        { "value": "allOrders", "label": "allOrders (symbol)" },
        { "value": "queryOrder", "label": "queryOrder (symbol + orderId or origClientOrderId)" },
        { "value": "myTrades", "label": "myTrades (symbol)" },
        { "value": "userStreamUrl", "label": "userStreamUrl (spot wss + listenKey)" },
        { "value": "listenKeyKeepalive", "label": "listenKeyKeepalive (PUT userDataStream)" },
        { "value": "listenKeyClose", "label": "listenKeyClose (DELETE userDataStream)" },
        { "value": "futuresTransfer", "label": "futuresTransfer (spot↔UM: asset + amount + type 1|2)" },
        { "value": "futuresTransferHistory", "label": "futuresTransferHistory (GET /sapi/v1/futures/transfer)" }
      ]
    },
    { "key": "recvWindow", "label": "recvWindow (ms, optional)", "inputType": "text" },
    { "key": "symbol", "label": "symbol", "inputType": "text" },
    { "key": "orderId", "label": "orderId", "inputType": "text" },
    { "key": "origClientOrderId", "label": "origClientOrderId", "inputType": "text" },
    { "key": "startTime", "label": "startTime (ms)", "inputType": "text" },
    { "key": "endTime", "label": "endTime (ms)", "inputType": "text" },
    { "key": "limit", "label": "limit", "inputType": "text" },
    { "key": "fromId", "label": "fromId (myTrades)", "inputType": "text" },
    { "key": "listenKey", "label": "listenKey (userStreamUrl)", "inputType": "text" },
    { "key": "wsStreamBase", "label": "wsStreamBase (default wss://sstream.asterdex.com/ws)", "inputType": "text" },
    { "key": "createListenKey", "label": "createListenKey (userStreamUrl)", "inputType": "text" },
    { "key": "transferAsset", "label": "transferAsset (futuresTransfer, e.g. USDT)", "inputType": "text" },
    { "key": "transferAmount", "label": "transferAmount (futuresTransfer)", "inputType": "text" },
    { "key": "futuresTransferType", "label": "futuresTransferType 1=spot→UM 2=UM→spot", "inputType": "text" },
    { "key": "transferHistoryAsset", "label": "transferHistoryAsset (optional filter)", "inputType": "text" },
    { "key": "transferHistoryPage", "label": "transferHistoryPage (current, default 1)", "inputType": "text" },
    { "key": "transferHistorySize", "label": "transferHistorySize (max 100)", "inputType": "text" },
    { "key": "saveResultVariable", "label": "Save JSON result to variable", "inputType": "text" }
  ]
}
