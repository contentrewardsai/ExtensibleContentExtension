{
  "id": "asterFuturesAccount",
  "label": "Aster futures (account read)",
  "category": "data",
  "description": "Signed USER_DATA reads: balances, positions, orders, trades, income, commission, ADL, force orders, leverage brackets, position/margin mode. Configure API key + secret in Settings.",
  "defaultAction": {
    "type": "asterFuturesAccount",
    "runIf": "",
    "operation": "balance",
    "recvWindow": "",
    "symbol": "",
    "orderId": "",
    "origClientOrderId": "",
    "startTime": "",
    "endTime": "",
    "limit": "",
    "fromId": "",
    "incomeType": "",
    "autoCloseType": "",
    "listenKey": "",
    "wsStreamBase": "",
    "createListenKey": "",
    "saveResultVariable": "asterAccountResult"
  },
  "formSchema": [
    { "key": "runIf", "label": "Run only if (optional)", "inputType": "text", "placeholder": "{{var}} or variable name" },
    {
      "key": "operation",
      "label": "Operation",
      "inputType": "select",
      "options": [
        { "value": "balance", "label": "balance (v2)" },
        { "value": "account", "label": "account (v4)" },
        { "value": "positionRisk", "label": "positionRisk (optional symbol)" },
        { "value": "openOrders", "label": "openOrders (optional symbol)" },
        { "value": "allOrders", "label": "allOrders (symbol)" },
        { "value": "queryOrder", "label": "queryOrder (symbol + orderId or origClientOrderId)" },
        { "value": "historicalTrades", "label": "historicalTrades (symbol; signed MARKET_DATA)" },
        { "value": "userTrades", "label": "userTrades (symbol)" },
        { "value": "income", "label": "income (optional filters)" },
        { "value": "commissionRate", "label": "commissionRate (symbol)" },
        { "value": "adlQuantile", "label": "adlQuantile (optional symbol)" },
        { "value": "forceOrders", "label": "forceOrders (optional filters)" },
        { "value": "leverageBracket", "label": "leverageBracket (optional symbol)" },
        { "value": "getPositionMode", "label": "getPositionMode (dual-side)" },
        { "value": "getMultiAssetsMargin", "label": "getMultiAssetsMargin" },
        { "value": "positionMarginHistory", "label": "positionMarginHistory (symbol + optional time/limit)" },
        { "value": "userStreamUrl", "label": "userStreamUrl (listenKey + wss URL; optional create)" }
      ]
    },
    { "key": "recvWindow", "label": "recvWindow (ms, optional)", "inputType": "text" },
    { "key": "symbol", "label": "symbol", "inputType": "text" },
    { "key": "orderId", "label": "orderId", "inputType": "text" },
    { "key": "origClientOrderId", "label": "origClientOrderId", "inputType": "text" },
    { "key": "startTime", "label": "startTime (ms)", "inputType": "text" },
    { "key": "endTime", "label": "endTime (ms)", "inputType": "text" },
    { "key": "limit", "label": "limit", "inputType": "text" },
    { "key": "fromId", "label": "fromId", "inputType": "text" },
    { "key": "incomeType", "label": "incomeType", "inputType": "text" },
    { "key": "autoCloseType", "label": "autoCloseType (forceOrders)", "inputType": "text" },
    { "key": "listenKey", "label": "listenKey (userStreamUrl; leave empty to POST new)", "inputType": "text" },
    { "key": "wsStreamBase", "label": "wsStreamBase (optional, default wss://fstream.asterdex.com/ws)", "inputType": "text" },
    { "key": "createListenKey", "label": "createListenKey (userStreamUrl: false = require listenKey)", "inputType": "text" },
    { "key": "saveResultVariable", "label": "Save JSON result to variable", "inputType": "text" }
  ]
}
