{
  "id": "solanaReadBalances",
  "label": "Solana read balances",
  "category": "data",
  "description": "Read-only RPC: native SOL balance for the automation wallet (or optional owner). If mint is set, also reads SPL token balance at the derived ATA. Does not unlock the wallet; owner defaults to stored public key hint.",
  "defaultAction": {
    "type": "solanaReadBalances",
    "runIf": "",
    "owner": "",
    "mint": "",
    "tokenProgram": "token",
    "cluster": "mainnet-beta",
    "rpcUrl": "",
    "saveNativeLamportsVariable": "solanaNativeLamports",
    "saveBalanceOwnerVariable": "solanaBalanceOwner",
    "saveTokenAmountRawVariable": "solanaTokenAmountRaw",
    "saveAtaAddressVariable": "solanaTokenAta",
    "saveAtaExistsVariable": "solanaAtaExists"
  },
  "formSchema": [
    { "key": "runIf", "label": "Run only if (optional)", "inputType": "text" },
    { "key": "owner", "label": "Owner (optional)", "inputType": "text", "placeholder": "Default: automation pubkey hint" },
    { "key": "mint", "label": "Mint (optional)", "inputType": "text", "placeholder": "If set, read SPL ATA balance" },
    { "key": "tokenProgram", "label": "Token program", "inputType": "select", "options": [
      { "value": "token", "label": "SPL Token" },
      { "value": "token-2022", "label": "Token-2022" }
    ] },
    { "key": "cluster", "label": "Cluster", "inputType": "select", "options": [
      { "value": "mainnet-beta", "label": "mainnet-beta" },
      { "value": "devnet", "label": "devnet" }
    ] },
    { "key": "rpcUrl", "label": "RPC URL override (optional)", "inputType": "text" },
    { "key": "saveNativeLamportsVariable", "label": "Save native lamports", "inputType": "text" },
    { "key": "saveBalanceOwnerVariable", "label": "Save resolved owner address", "inputType": "text" },
    { "key": "saveTokenAmountRawVariable", "label": "Save token amount raw (if mint set)", "inputType": "text" },
    { "key": "saveAtaAddressVariable", "label": "Save ATA address (if mint set)", "inputType": "text" },
    { "key": "saveAtaExistsVariable", "label": "Save ATA exists true/false", "inputType": "text" }
  ]
}
