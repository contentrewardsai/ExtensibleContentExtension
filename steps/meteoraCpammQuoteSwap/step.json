{
  "id": "meteoraCpammQuoteSwap",
  "label": "Meteora CP-AMM quote (swap)",
  "category": "data",
  "description": "Read-only **exact-in** quote for a Meteora DAMM v2 / CP-AMM pool (`CFS_METEORA_CPAMM_QUOTE_SWAP`). Same fields as **meteoraCpammSwap** (except swap-only options) but **no transaction** and **no wallet keypair** — RPC only. Writes optional row variables for expected / min out (raw) and **slippageBps** used by the SDK quote. Feed saved **min out** into **meteoraCpammSwap** → **minimumAmountOutRaw** (e.g. `{{cpammQuoteMinOutRaw}}`) for a stricter floor. Rebuild: `npm run build:meteora-cpamm`.",
  "defaultAction": {
    "type": "meteoraCpammQuoteSwap",
    "runIf": "",
    "pool": "",
    "inputMint": "",
    "outputMint": "",
    "amountInRaw": "",
    "slippagePercent": 1,
    "cluster": "mainnet-beta",
    "rpcUrl": "",
    "saveExpectedOutVariable": "cpammQuoteExpectedOutRaw",
    "saveMinOutVariable": "cpammQuoteMinOutRaw",
    "saveSlippageBpsVariable": ""
  },
  "formSchema": [
    { "key": "runIf", "label": "Run only if (optional)", "inputType": "text" },
    { "key": "pool", "label": "CP-AMM pool address", "inputType": "text" },
    { "key": "inputMint", "label": "Input token mint", "inputType": "text" },
    { "key": "outputMint", "label": "Output token mint", "inputType": "text" },
    { "key": "amountInRaw", "label": "Amount in (raw)", "inputType": "text" },
    { "key": "slippagePercent", "label": "Slippage (percent → min out)", "inputType": "number" },
    { "key": "cluster", "label": "Cluster", "inputType": "select", "options": [
      { "value": "mainnet-beta", "label": "mainnet-beta" },
      { "value": "devnet", "label": "devnet" }
    ] },
    { "key": "rpcUrl", "label": "RPC override", "inputType": "text" },
    { "key": "saveExpectedOutVariable", "label": "Save quoted out (raw)", "inputType": "text" },
    { "key": "saveMinOutVariable", "label": "Save min out after slippage (raw)", "inputType": "text" },
    { "key": "saveSlippageBpsVariable", "label": "Save slippage bps used (optional)", "inputType": "text" }
  ]
}
