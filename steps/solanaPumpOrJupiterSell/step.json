{
  "id": "solanaPumpOrJupiterSell",
  "label": "Solana Pump or Jupiter sell (to SOL)",
  "category": "data",
  "description": "Runs the Pump/Raydium probe, then sells via Pump.fun bonding curve if still active; otherwise Jupiter mint → WSOL. Same optional Jupiter fee/CU fields and probe row vars as solanaPumpOrJupiterBuy. `tokenAmountRaw` is smallest units. Saves venue (pump|jupiter).",
  "defaultAction": {
    "type": "solanaPumpOrJupiterSell",
    "runIf": "",
    "mint": "",
    "tokenAmountRaw": "",
    "pumpSlippage": 1,
    "jupiterSlippageBps": 50,
    "cluster": "mainnet-beta",
    "rpcUrl": "",
    "checkRaydium": true,
    "requireRaydiumPoolForPump": false,
    "skipPumpIfRaydiumPoolFound": false,
    "quoteMint": "So11111111111111111111111111111111111111112",
    "raydiumPageSize": 20,
    "skipSimulation": false,
    "skipPreflight": false,
    "onlyDirectRoutes": false,
    "jupiterDexes": "",
    "jupiterExcludeDexes": "",
    "jupiterPrioritizationFeeLamports": "",
    "jupiterDynamicComputeUnitLimit": true,
    "jupiterWrapAndUnwrapSol": true,
    "saveVenueVariable": "sellVenue",
    "saveRaydiumPoolCheckVariable": "",
    "saveRaydiumSpotPoolFoundVariable": "",
    "saveRaydiumPoolCountVariable": "",
    "savePumpBondingCurveCompleteVariable": "",
    "savePumpOnBondingCurveVariable": "",
    "savePumpProbeErrorVariable": "",
    "saveRaydiumDetailVariable": "",
    "saveSignatureVariable": "solanaTxSignature",
    "saveExplorerUrlVariable": "solanaExplorerUrl"
  },
  "formSchema": [
    { "key": "runIf", "label": "Run only if (optional)", "inputType": "text" },
    { "key": "mint", "label": "Token mint", "inputType": "text" },
    { "key": "tokenAmountRaw", "label": "Amount to sell (raw)", "inputType": "text" },
    { "key": "pumpSlippage", "label": "Pump SDK slippage (if Pump path)", "inputType": "number" },
    { "key": "jupiterSlippageBps", "label": "Jupiter slippage bps (if Jupiter path)", "inputType": "number" },
    { "key": "cluster", "label": "Cluster", "inputType": "select", "options": [
      { "value": "mainnet-beta", "label": "mainnet-beta" },
      { "value": "devnet", "label": "devnet" }
    ] },
    { "key": "rpcUrl", "label": "RPC override", "inputType": "text" },
    { "key": "checkRaydium", "label": "Probe: check Raydium (mainnet)", "inputType": "checkbox" },
    { "key": "requireRaydiumPoolForPump", "label": "Pump path only if Raydium pool found", "inputType": "checkbox" },
    { "key": "skipPumpIfRaydiumPoolFound", "label": "Use Jupiter if Raydium pool found (even on curve)", "inputType": "checkbox" },
    { "key": "quoteMint", "label": "Probe quote mint", "inputType": "text" },
    { "key": "raydiumPageSize", "label": "Raydium page size", "inputType": "number" },
    { "key": "skipSimulation", "label": "Skip simulation", "inputType": "checkbox" },
    { "key": "skipPreflight", "label": "Skip preflight", "inputType": "checkbox" },
    { "key": "onlyDirectRoutes", "label": "Jupiter: direct routes only", "inputType": "checkbox" },
    { "key": "jupiterDexes", "label": "Jupiter include DEXes", "inputType": "text" },
    { "key": "jupiterExcludeDexes", "label": "Jupiter exclude DEXes", "inputType": "text" },
    { "key": "jupiterPrioritizationFeeLamports", "label": "Jupiter: prioritization fee (lamports, Jupiter path)", "inputType": "text", "placeholder": "empty = auto, or integer, or auto" },
    { "key": "jupiterDynamicComputeUnitLimit", "label": "Jupiter: dynamic compute unit limit", "inputType": "checkbox" },
    { "key": "jupiterWrapAndUnwrapSol", "label": "Jupiter: auto wrap/unwrap SOL (Jupiter path)", "inputType": "checkbox" },
    { "key": "saveVenueVariable", "label": "Save venue (pump/jupiter)", "inputType": "text" },
    { "key": "saveRaydiumPoolCheckVariable", "label": "Save Raydium pool check (optional)", "inputType": "text" },
    { "key": "saveRaydiumSpotPoolFoundVariable", "label": "Save Raydium found true/false/unknown (optional)", "inputType": "text" },
    { "key": "saveRaydiumPoolCountVariable", "label": "Save Raydium pool count (optional)", "inputType": "text" },
    { "key": "savePumpBondingCurveCompleteVariable", "label": "Save curve complete true/false/unknown (optional)", "inputType": "text" },
    { "key": "savePumpOnBondingCurveVariable", "label": "Save on-curve true/false (optional)", "inputType": "text" },
    { "key": "savePumpProbeErrorVariable", "label": "Save Pump probe error if any (optional)", "inputType": "text" },
    { "key": "saveRaydiumDetailVariable", "label": "Save Raydium probe detail if any (optional)", "inputType": "text" },
    { "key": "saveSignatureVariable", "label": "Save tx signature", "inputType": "text" },
    { "key": "saveExplorerUrlVariable", "label": "Save explorer URL", "inputType": "text" }
  ]
}
