{
  "id": "raydiumAddLiquidity",
  "label": "Raydium add liquidity (Standard AMM)",
  "category": "data",
  "description": "Add liquidity to a Raydium **Standard** pool (OpenBook-linked AMM v4/v5). Not for CLMM or CPMM pools. `fixedSide` is **a** (mint A) or **b** (mint B); `amountInRaw` is the integer deposit in that side's smallest units. Rebuild after SDK upgrades: npm run build:raydium.",
  "defaultAction": {
    "type": "raydiumAddLiquidity",
    "runIf": "",
    "poolId": "",
    "fixedSide": "a",
    "amountInRaw": "",
    "slippageBps": 50,
    "cluster": "mainnet-beta",
    "rpcUrl": "",
    "skipSimulation": false,
    "skipPreflight": false,
    "saveSignatureVariable": "solanaTxSignature",
    "saveExplorerUrlVariable": "solanaExplorerUrl"
  },
  "formSchema": [
    {
      "key": "runIf",
      "label": "Run only if (optional)",
      "inputType": "text"
    },
    {
      "key": "poolId",
      "label": "Pool id (base58)",
      "inputType": "poolSearch",
      "poolSearchMessage": "CFS_RAYDIUM_POOL_SEARCH",
      "poolSearchDeps": [
        "inputMint",
        "outputMint"
      ],
      "placeholder": "Paste pool ID or search by token pair"
    },
    {
      "key": "fixedSide",
      "label": "Fixed side",
      "inputType": "select",
      "options": [
        {
          "value": "a",
          "label": "a (mint A)"
        },
        {
          "value": "b",
          "label": "b (mint B)"
        }
      ]
    },
    {
      "key": "amountInRaw",
      "label": "Amount in (raw, fixed side)",
      "inputType": "text"
    },
    {
      "key": "slippageBps",
      "label": "Slippage (basis points)",
      "inputType": "number"
    },
    {
      "key": "cluster",
      "label": "Cluster",
      "inputType": "select",
      "options": [
        {
          "value": "mainnet-beta",
          "label": "mainnet-beta"
        },
        {
          "value": "devnet",
          "label": "devnet"
        }
      ]
    },
    {
      "key": "rpcUrl",
      "label": "RPC override",
      "inputType": "text"
    },
    {
      "key": "skipSimulation",
      "label": "Skip simulation",
      "inputType": "checkbox"
    },
    {
      "key": "skipPreflight",
      "label": "Skip preflight",
      "inputType": "checkbox"
    },
    {
      "key": "saveSignatureVariable",
      "label": "Save signature variable",
      "inputType": "text"
    },
    {
      "key": "saveExplorerUrlVariable",
      "label": "Save explorer URL variable",
      "inputType": "text"
    }
  ]
}