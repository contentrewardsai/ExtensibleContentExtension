{
  "id": "raydiumCpmmRemoveLiquidity",
  "label": "Raydium remove liquidity (CPMM)",
  "category": "data",
  "description": "Withdraw from a Raydium **CPMM** pool by burning LP (raw amount). Slippage applies to minimum token outs inside the SDK. **closeWsol** (default true) matches SDK default for WSOL accounts. Not Standard/CLMM.",
  "defaultAction": {
    "type": "raydiumCpmmRemoveLiquidity",
    "runIf": "",
    "poolId": "",
    "lpAmountRaw": "",
    "slippageBps": 50,
    "cluster": "mainnet-beta",
    "rpcUrl": "",
    "closeWsol": true,
    "skipSimulation": false,
    "skipPreflight": false,
    "saveSignatureVariable": "solanaTxSignature",
    "saveExplorerUrlVariable": "solanaExplorerUrl"
  },
  "formSchema": [
    {
      "key": "runIf",
      "label": "Run only if (optional)",
      "inputType": "text"
    },
    {
      "key": "poolId",
      "label": "CPMM pool id",
      "inputType": "poolSearch",
      "poolSearchMessage": "CFS_RAYDIUM_POOL_SEARCH",
      "poolSearchDeps": [
        "inputMint",
        "outputMint"
      ],
      "placeholder": "Paste pool ID or search by token pair"
    },
    {
      "key": "lpAmountRaw",
      "label": "LP to burn (raw)",
      "inputType": "text"
    },
    {
      "key": "slippageBps",
      "label": "Slippage (basis points)",
      "inputType": "number"
    },
    {
      "key": "cluster",
      "label": "Cluster",
      "inputType": "select",
      "options": [
        {
          "value": "mainnet-beta",
          "label": "mainnet-beta"
        },
        {
          "value": "devnet",
          "label": "devnet"
        }
      ]
    },
    {
      "key": "rpcUrl",
      "label": "RPC override",
      "inputType": "text"
    },
    {
      "key": "closeWsol",
      "label": "Close WSOL accounts (SDK default)",
      "inputType": "checkbox"
    },
    {
      "key": "skipSimulation",
      "label": "Skip simulation",
      "inputType": "checkbox"
    },
    {
      "key": "skipPreflight",
      "label": "Skip preflight",
      "inputType": "checkbox"
    },
    {
      "key": "saveSignatureVariable",
      "label": "Save signature variable",
      "inputType": "text"
    },
    {
      "key": "saveExplorerUrlVariable",
      "label": "Save explorer URL variable",
      "inputType": "text"
    }
  ]
}