.DS_Store
.cursor
.cursorrules
Thumbs.db
node_modules/
# Large weights under models/ — keep README / placeholder tracked
models/*
!models/README.md
!models/.gitkeep

# Environment / secrets
.env
.env.local
.env.*.local

# E2E persistent profile (user data dir)
test/.e2e-user-data*/
test/.e2e-*-profile/

# Build / test artifacts
# Chain SDK bundles under background/*.bundle.js are committed so `npm ci` alone
# is enough to load the extension; run `npm run build:chain-bundles` after dep bumps.
test/e2e-step-config.json
playwright-report/
test-results/

# Extension signing keys (never commit)
*.pem

# BSC / EVM hot wallet local overrides (never commit secrets)
config/bsc-wallet.local.json

# Solana automation: never commit local key material or backups
config/solana-local.json
**/solana-keypair*.json
solana-keypair*.json

# Logs
*.log

# Local/user data (do not commit) — tracked files are whitelisted (config/ has no subdirs in-repo)
config/*
!config/whop-auth.example.js
!config/solana-local.example.json

# Editor / IDE (local; keep machine-specific settings out of the repo)
.vscode/
following/*
!following/README.md
uploads/*
!uploads/README.md

# Workflows: track shared QA/e2e templates and root docs; ignore per-user dirs (wf_*…) and their runs/media
workflows/*
!workflows/README.md
!workflows/manifest.json
!workflows/qa/
workflows/qa/**
!workflows/qa/.gitkeep
!workflows/e2e-test/
!workflows/e2e-test/**

# Optional: generated exports / captures
generator/outputs/*.tmp

# GitHub incremental sync baseline (written by side panel; see github-sync-state.example.json)
github-sync-state.json
coverage-report.json
coverage-baseline.json

# MCP server compiled binaries and config (contains bearer token)
mcp-server/ec-mcp-server-*
mcp-server/StartMCPServer*
ec-mcp-config.json
