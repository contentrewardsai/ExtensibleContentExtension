.DS_Store
.cursor
.cursorrules
Thumbs.db
node_modules/
# Large weights under models/ — keep README / placeholder tracked
models/*
!models/README.md
!models/.gitkeep

# Environment / secrets
.env
.env.local
.env.*.local

# E2E persistent profile (user data dir)
test/.e2e-user-data*/

# Build / test artifacts
test/e2e-step-config.json
playwright-report/
test-results/

# Extension signing keys (never commit)
*.pem

# Logs
*.log

# Local/user data (do not commit)
config/**
!config/whop-auth.example.js
following/*
!following/README.md
uploads/*
!uploads/README.md

# Workflows: track shared QA/e2e templates and root docs; ignore per-user dirs (wf_*…) and their runs/media
workflows/*
!workflows/README.md
!workflows/manifest.json
!workflows/qa/
workflows/qa/**
!workflows/qa/.gitkeep
!workflows/e2e-test/
!workflows/e2e-test/**

# Optional: generated exports / captures
generator/outputs/*.tmp

# FFmpeg WASM binary (large, regenerate via setup-ffmpeg.sh)
lib/ffmpeg/ffmpeg-core.wasm
