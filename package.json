{
  "name": "content-for-sales",
  "version": "1.0.0",
  "private": true,
  "description": "Chrome extension for recording and automating workflows",
  "scripts": {
    "build:evm": "esbuild scripts/evm-bundle-entry.js --bundle --platform=browser --format=iife --legal-comments=none --supported:exponent-operator=false --outfile=background/evm-lib.bundle.js && node scripts/patch-bundle-pow-helper.mjs background/evm-lib.bundle.js",
    "build:solana": "node scripts/build-solana-bundle.mjs",
    "build:pump": "esbuild scripts/pump-bundle-entry.js --bundle --platform=browser --format=iife --legal-comments=none --supported:exponent-operator=false --outfile=background/pump-sdk.bundle.js && node scripts/patch-bundle-pow-helper.mjs background/pump-sdk.bundle.js",
    "build:raydium": "esbuild scripts/raydium-bundle-entry.js --bundle --platform=browser --format=iife --legal-comments=none --alias:stream=stream-browserify --alias:events=events --supported:exponent-operator=false --outfile=background/raydium-sdk.bundle.js && node scripts/patch-bundle-pow-helper.mjs background/raydium-sdk.bundle.js",
    "build:meteora": "esbuild scripts/meteora-dlmm-bundle-entry.js --bundle --platform=browser --format=iife --legal-comments=none --alias:stream=stream-browserify --alias:events=events --alias:util=util --supported:exponent-operator=false --outfile=background/meteora-dlmm.bundle.js && node scripts/patch-bundle-pow-helper.mjs background/meteora-dlmm.bundle.js",
    "build:meteora-cpamm": "esbuild scripts/meteora-cpamm-bundle-entry.js --bundle --platform=browser --format=iife --legal-comments=none --alias:stream=stream-browserify --alias:events=events --alias:util=util --supported:exponent-operator=false --outfile=background/meteora-cpamm.bundle.js && node scripts/patch-bundle-pow-helper.mjs background/meteora-cpamm.bundle.js",
    "build:infinity": "esbuild scripts/infinity-bundle-entry.js --bundle --platform=browser --format=iife --legal-comments=none --alias:stream=stream-browserify --alias:events=events --alias:util=util --supported:exponent-operator=false --outfile=background/infinity-sdk.bundle.js && node scripts/patch-bundle-pow-helper.mjs background/infinity-sdk.bundle.js",
    "build:chain-bundles": "npm run build:evm && npm run build:solana && npm run build:pump && npm run build:raydium && npm run build:meteora && npm run build:meteora-cpamm && npm run build:infinity",
    "check:content-bundle": "node scripts/check-content-bundle.cjs",
    "vendor:ffmpeg": "node scripts/vendor-ffmpeg.cjs",
    "test:ffmpeg-vendor": "node scripts/verify-ffmpeg-vendor.cjs",
    "validate:steps": "node scripts/validate-step-definitions.cjs",
    "report:step-test-coverage": "node scripts/report-step-test-coverage.mjs",
    "report:test-landscape": "node scripts/report-test-landscape.mjs",
    "build:step-tests": "node scripts/build-step-tests.cjs",
    "test:e2e": "npm run build:step-tests && node scripts/build-step-e2e.cjs && npx playwright test",
    "test:e2e:ci": "npm run build:step-tests && node scripts/build-step-e2e.cjs && CI=1 npx playwright test",
    "test:e2e:ci-smoke": "npm run build:step-tests && node scripts/build-step-e2e.cjs && CI=1 PW_WORKERS=1 npx playwright test test/e2e/api.spec.mjs test/e2e/content.spec.mjs",
    "test:e2e:install-browsers": "npx playwright install chromium",
    "test:e2e:puppeteer": "node scripts/run-e2e-puppeteer.mjs",
    "test:evm-bundle": "node scripts/verify-evm-bundle.mjs",
    "test:bsc-watch-wired": "node scripts/verify-bsc-watch-wired.cjs",
    "test:bsc-following-venues-wired": "node scripts/verify-bsc-following-venues-wired.cjs",
    "test:aster-futures-wired": "node scripts/verify-aster-futures-wired.cjs",
    "test:aster-rate-limit-parse": "node scripts/verify-aster-rate-limit-parse.cjs",
    "test:cfs-always-on-wired": "node scripts/verify-cfs-always-on-wired.cjs",
    "test:crypto-rate-limit-wired": "node scripts/verify-crypto-rate-limit-wired.cjs",
    "test:crypto-workflow-step-types": "node scripts/verify-crypto-workflow-step-types.cjs",
    "test:sellability-probe-wired": "node scripts/verify-sellability-probe-wired.cjs",
    "test:bsc-v3-npm-query-wired": "node scripts/verify-bsc-v3-npm-query-wired.cjs",
    "test:bsc-infinity-wired": "node scripts/verify-bsc-infinity-wired.cjs",
    "test:infi-bin-path-json": "node scripts/verify-infi-bin-path-json.cjs",
    "test:remote-llm-wired": "node scripts/verify-remote-llm-wired.cjs",
    "test:solana-bundle": "node scripts/verify-solana-bundle.mjs",
    "test:pump-bundle": "node scripts/verify-pump-bundle.mjs",
    "test:raydium-bundle": "node scripts/verify-raydium-bundle.mjs",
    "test:meteora-dlmm-bundle": "node scripts/verify-meteora-dlmm-bundle.mjs",
    "test:meteora-cpamm-bundle": "node scripts/verify-meteora-cpamm-bundle.mjs",
    "test:infinity-bundle": "node scripts/verify-infinity-bundle.mjs",
    "test:solana": "npm run test:solana-bundle && npm run test:pump-bundle && npm run test:raydium-bundle && npm run test:meteora-dlmm-bundle && npm run test:meteora-cpamm-bundle",
    "test:unit": "node scripts/run-unit-tests.mjs",
    "test:apify-dataset-parse": "node scripts/verify-apify-dataset-parse.mjs",
    "test:apify-run-query-validation": "node scripts/verify-apify-run-query-validation.mjs",
    "test:apify-extract-run-id": "node scripts/verify-apify-extract-run-id.mjs",
    "test:apify": "npm run test:apify-dataset-parse && npm run test:apify-run-query-validation && npm run test:apify-extract-run-id",
    "test:project-id-resolve": "node scripts/verify-project-id-resolve.cjs",
    "test:recorder-integration": "node scripts/run-recorder-integration-tests.mjs",
    "test:crypto-rpc-smoke": "node scripts/crypto-rpc-smoke.mjs",
    "report:crypto-matrix": "node scripts/crypto-step-matrix.mjs --write",
    "verify:crypto-matrix": "node scripts/crypto-step-matrix.mjs --check",
    "test:crypto-evm-fork-smoke": "node scripts/crypto-evm-fork-smoke.mjs",
    "test:crypto-manifest-hosts": "node scripts/verify-crypto-manifest-hosts.cjs",
    "test:crypto-observability-wired": "node scripts/verify-crypto-observability-wired.cjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "esbuild": "^0.25.12",
    "playwright": "^1.49.0",
    "puppeteer": "^24.0.0"
  },
  "dependencies": {
    "@ffmpeg/core": "^0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@meteora-ag/cp-amm-sdk": "^1.4.0",
    "@meteora-ag/dlmm": "^1.9.4",
    "@pancakeswap/infinity-sdk": "^1.0.8",
    "@pump-fun/pump-sdk": "^1.32.0",
    "@raydium-io/raydium-sdk-v2": "^0.2.32-alpha",
    "@scure/bip39": "^2.0.1",
    "@solana/spl-token": "^0.4.13",
    "@solana/web3.js": "^1.98.4",
    "bn.js": "^5.2.3",
    "bs58": "^6.0.0",
    "buffer": "^6.0.3",
    "ed25519-hd-key": "^1.3.0",
    "ethers": "^6.16.0",
    "events": "^3.3.0",
    "stream-browserify": "^3.0.0",
    "util": "^0.12.5"
  },
  "overrides": {
    "bn.js": "^5.2.3",
    "bigint-buffer": "npm:bigint-buffer-fixed@1.1.6",
    "@tootallnate/once": "^3.0.2",
    "tar": "^7.5.2",
    "cacache": "^19.0.0",
    "make-fetch-happen": "^14.0.0",
    "http-proxy-agent": "^7.0.2",
    "node-gyp": "^11.2.0"
  }
}
