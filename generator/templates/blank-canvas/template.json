    { "find": "__CFS_INPUT_SCHEMA", "replace": "[{\"id\":\"backgroundColor\",\"label\":\"Background\",\"type\":\"color\",\"default\":\"#ffffff\",\"mergeField\":\"BACKGROUND_COLOR\"},{\"id\":\"outputWidth\",\"label\":\"Width (px)\",\"type\":\"number\",\"default\":1080},{\"id\":\"outputHeight\",\"label\":\"Height (px)\",\"type\":\"number\",\"default\":1080}]" }
